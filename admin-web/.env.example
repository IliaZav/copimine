# CopiMine Ultimate Admin v2.1
# Copy to .env only for a new install. Never overwrite the production .env.

MC_SERVER_DIR=/opt/copimine/minecraft/server
MC_WORLD_DIR=/opt/copimine/minecraft/server/CopiMine
MC_HOST=127.0.0.1
MC_PORT=25565

RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=CHANGE_ME
MINECRAFT_SERVICE=copimine-minecraft
# LuckPerms group that may create ImageFrame maps. Ordinary players are denied.
COPIMINE_IMAGEFRAME_ADMIN_GROUP=admin
# Simple Voice Chat on an offline-mode server with a public/wildcard UDP bind
# must be explicitly acknowledged. Keep this disabled unless the operator has
# assessed the identity-spoofing limitation and documented the exception.
COPIMINE_ALLOW_INSECURE_OFFLINE_VOICECHAT=0
COPIMINE_OFFLINE_VOICECHAT_EXCEPTION_REASON=

COREPROTECT_DB=/opt/copimine/minecraft/server/plugins/CoreProtect/database.db
ADMIN_PLUGIN_DB=/opt/copimine/minecraft/server/plugins/CopiMineUltimateAdmin/copimine_ultimate.db
MC_LOG_FILE=/opt/copimine/minecraft/server/logs/latest.log

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=copimine
POSTGRES_USER=copimine
POSTGRES_SCHEMA=copimine
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://copimine:CHANGE_ME@127.0.0.1:5432/copimine
COPIMINE_AUTH_STORAGE=postgresql
COPIMINE_ENV_FILE=/opt/copimine/admin-web/.env
COPIMINE_PLUGIN_DB_POOL_SIZE=4
COPIMINE_PLUGIN_DB_CONNECT_TIMEOUT_MS=5000
COPIMINE_PLUGIN_DB_STATEMENT_TIMEOUT_MS=5000

COPIMINE_ADMIN_DATA=/opt/copimine/admin-web/data
COPIMINE_BACKUPS_DIR=/opt/copimine/admin-web/backups
COPIMINE_SECRETS_DIR=/opt/copimine-secrets
MINECRAFT_ASSETS_VERSION=1.21.1

# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME
PLUGIN_API_KEY=CHANGE_ME
AUTH_COOKIE_SECURE=0
# Only use HTTP authentication on a trusted temporary network. It keeps the
# current no-TLS install usable, but credentials and sessions are not protected
# from network interception. Set this to 0 before exposing the panel publicly.
# Public pages/downloads work over HTTP. Enable only on a trusted LAN while
# migrating to TLS; production login should use HTTPS.
ALLOW_INSECURE_HTTP_AUTH=0
SESSION_TTL_SECONDS=28800
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_SECONDS=900

# Admins are loaded from data/admin_users.json or from ADMIN_USERS_JSON.
# Store only pbkdf2/sha256 hashes, never plaintext passwords.
ADMIN_USERS_JSON={}
REQUIRE_OP_FOR_LOGIN=1
REQUIRE_WHITELIST_FOR_LOGIN=1

ALLOWED_ORIGINS=
DB_WRITE_ENABLED=0
ADMIN_DB_WRITE_ALLOWLIST=

AR_ITEM_IDS=minecraft:amethyst_shard,AMETHYST_SHARD
MAX_WORLD_REGION_FILES=24
MAX_WORLD_CHUNKS=1200

# Safe RCON command center. Player/server actions use separate backend templates.
RCON_WEB_COMMAND_ALLOWLIST=list,tps,mspt,say,save-all,time query,weather query

# Discord bot. Token and API keys must stay only in .env.
DISCORD_BOT_TOKEN=CHANGE_ME
DISCORD_GUILD_ID=CHANGE_ME
DISCORD_APPLICATIONS_CHANNEL_ID=CHANGE_ME
DISCORD_APPLICATIONS_ADMIN_CHANNEL_ID=
DISCORD_REPORTS_CHANNEL_ID=CHANGE_ME
DISCORD_REPORTS_ADMIN_CHANNEL_ID=
DISCORD_SERVER_STATUS_CHANNEL_ID=
DISCORD_ELECTIONS_STATUS_CHANNEL_ID=
DISCORD_ADMIN_ALERTS_CHANNEL_ID=
DISCORD_ADMIN_ROLE_ID=CHANGE_ME
DISCORD_ADMIN_ALLOWLIST=
# Comma-separated numeric Discord role IDs allowed to approve whitelist requests.
# Role names are deliberately unsupported because they can be renamed by users.
DISCORD_WHITELIST_APPROVER_ROLE_IDS=
DISCORD_BOT_API_KEY=CHANGE_ME
ADMIN_PUBLIC_BASE_URL=http://admin.copimine.ru:18080
PUBLIC_PANEL_URL=http://copimine.ru:18080
BACKEND_INTERNAL_BASE_URL=http://127.0.0.1:8090
TRUSTED_PROXY_IPS=127.0.0.1,::1
# Set all of these together when a certificate is installed. The installer then
# forces secure cookies and disables HTTP login while keeping downloads served.
COPIMINE_TLS_ENABLED=0
COPIMINE_TLS_CERT_PATH=
COPIMINE_TLS_KEY_PATH=
NGINX_SERVER_NAMES=admin.copimine.ru copimine.ru www.copimine.ru
RESOURCE_PACK_PUBLIC_URL=http://copimine.ru:18080/resourcepacks/CopiMineResourcePack.zip

# YooKassa is disabled until both credentials are stored in the production .env.
# Never commit the secret key or add it to frontend code.
YOOKASSA_ENABLED=0
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_BASE_URL=https://api.yookassa.ru/v3
YOOKASSA_RETURN_URL=https://copimine.ru/cabinet/donation-balance.html

COPIMINE_SYSTEMD_SERVICES=copimine-minecraft,copimine-game-hardening,copimine-admin,copimine-discord-bot,nginx,tailscaled,ssh
